    {
      "title": "Tomato Garlic Pasta",
      "ingredientsText": "400 g Pasta\n2 cups Tomato Sauce\n3 cloves Garlic\n2 tbsp Extra Virgin Olive Oil\n1/2 cup Basil",
      "instructions": "1. Bring a large pot of salted water to a boil and cook the pasta until al dente.\n2. In a saucepan, warm the tomato sauce with minced garlic and torn basil.\n3. Drain the pasta, toss with the sauce and a drizzle of olive oil, and serve.",
      "lines": [
        {
          "sortOrder": 0,
          "ingredientName": "Pasta",
          "quantityNote": "400 g"
        },
        {
          "sortOrder": 1,
          "ingredientName": "Tomato Sauce",
          "quantityNote": "2 cups"
        },
        {
          "sortOrder": 2,
